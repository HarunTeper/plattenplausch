# Copy to `.env` for local dev, or set these as GitLab CI/CD variables for the build.
# Nothing here is secret — the Turnstile *secret* lives only in Apps Script Script Properties.

# The Apps Script Web App /exec URL (stable deployment id — see README).
VITE_WEBAPP_URL=https://script.google.com/macros/s/AKfycbxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx/exec

# Google Sheet gviz/tq endpoint for the standings (fresher than publish-to-web CSV).
# Default season table is Ranking_Gesamt; swap to Ranking_Hin / Ranking_Rueck if
# you want the website to show a single round instead of the combined table.
# Format: https://docs.google.com/spreadsheets/d/<SHEET_ID>/gviz/tq?sheet=Ranking_Gesamt
VITE_RANKING_CSV_URL=https://docs.google.com/spreadsheets/d/REPLACE_SHEET_ID/gviz/tq?sheet=Ranking_Gesamt

# Cloudflare Turnstile site key (public). Use the test key below for local dev:
# 1x00000000000000000000AA always passes; 2x00000000000000000000AB always blocks.
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Optional: base path if deploying under a GitLab Pages subpath instead of a custom domain.
# VITE_BASE=/plattenplausch/
